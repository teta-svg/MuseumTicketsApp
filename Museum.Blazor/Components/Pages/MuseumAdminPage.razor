@page "/admin/museum"
@using Museum.Application.DTOs
@using Microsoft.AspNetCore.Components.Forms
@inject HttpClient Http
@inject IJSRuntime JS

@rendermode InteractiveServer

<div class="container-fluid py-4 admin-page-container">
    <div class="admin-header">
        <div>
            <h3 class="header-title">УПРАВЛЕНИЕ ВЫСТАВКАМИ</h3>
            <p class="text-muted mb-0 small">Контроль текущих экспозиций и продаж</p>
        </div>
        <button class="btn btn-museum-dark shadow-sm" @onclick="OpenModal">
            <i class="bi bi-plus-lg me-2"></i>НОВАЯ ВЫСТАВКА
        </button>
    </div>

    <div class="row align-items-start">
        <div class="col-lg-8">
            <div class="row">
                @if (salesReports == null)
                {
                    <div class="text-center p-5 w-100">
                        <div class="spinner-border text-dark"></div>
                    </div>
                }
                else if (!salesReports.Any())
                {
                    <div class="col-12">
                        <div class="empty-state shadow-sm text-center p-5">
                            <i class="bi bi-folder2-open display-4 text-muted mb-3 d-block"></i>
                            <h5 class="text-muted">Список пуст</h5>
                        </div>
                    </div>
                }
                else
                {
                    @foreach (var report in salesReports)
                    {
                        <div class="col-md-6 mb-4">
                            <div class="card h-100 card-museum shadow-sm rounded-4 @(selectedReport?.ExhibitionId == report.ExhibitionId ? "card-selected" : "")"
                                 @onclick="() => selectedReport = report" style="cursor:pointer;">
                                <div class="card-body p-4">
                                    <h5 class="fw-bold text-dark mb-1">@report.ExhibitionName</h5>
                                    <div class="text-muted small mb-3">ID объекта: @report.ExhibitionId</div>
                                    <div class="d-flex justify-content-between align-items-center mt-3 pt-3 border-top">
                                        <div class="ticket-label">Билетов продано</div>
                                        <span class="badge badge-museum px-3 py-2 rounded-pill">@report.TicketsSold шт.</span>
                                    </div>
                                </div>
                            </div>
                        </div>
                    }
                }
            </div>
        </div>

        <div class="col-lg-4">
            @if (selectedReport != null)
            {
                <div class="card border-0 shadow-lg rounded-4 sticky-top actions-card animate__animated animate__fadeInRight">
                    <div class="card-header text-white rounded-top-4 py-3 text-center border-0 fw-bold actions-header">
                        ДЕЙСТВИЯ
                    </div>
                    <div class="card-body p-4 text-center">
                        <h6 class="fw-bold mb-4 text-uppercase">@selectedReport.ExhibitionName</h6>
                        <button class="btn btn-museum-dark w-100 mb-3 py-2 fw-bold shadow-sm" style="border-radius: 50px;" @onclick="CloseSales">
                            <i class="bi bi-lock-fill me-2"></i>ЗАКРЫТЬ ПРОДАЖИ
                        </button>
                        <hr class="museum-hr" />
                        <button class="btn btn-link btn-delete w-100 py-2" @onclick="DeleteExhibition">
                            <i class="bi bi-trash me-2"></i>УДАЛИТЬ ОБЪЕКТ
                        </button>
                    </div>
                </div>
            }
            else
            {
                <div class="selection-placeholder text-center p-5">
                    <i class="bi bi-arrow-left-circle d-block mb-3 opacity-25" style="font-size: 2rem;"></i>
                    <p class="text-muted small mb-0">Выберите выставку для управления</p>
                </div>
            }
        </div>
    </div>
</div>

@if (showModal)
{
    <div class="modal d-block museum-modal-wrapper" tabindex="-1">
        <div class="modal-dialog modal-lg modal-dialog-centered">
            <div class="modal-content border-0 shadow-lg rounded-4 overflow-hidden">
                <div class="modal-header museum-modal-header">
                    <h5 class="modal-title museum-modal-title">Регистрация новой выставки</h5>
                    <button type="button" class="btn-close btn-close-white" @onclick="CloseModal"></button>
                </div>

                <EditForm Model="@newExhibition" OnValidSubmit="SaveExhibition">
                    <DataAnnotationsValidator />
                    <div class="modal-body museum-modal-body">
                        <ValidationSummary class="alert alert-dark py-2 mb-4 rounded-3 small" />
                        
                        <div class="row g-3 mb-4">
                            <div class="col-12">
                                <label class="museum-label">Название экспозиции</label>
                                <InputText @bind-Value="newExhibition.Name" class="form-control museum-input" placeholder="Введите название..." required />
                            </div>
                            <div class="col-md-6">
                                <label class="museum-label">Дата начала</label>
                                <InputDate @bind-Value="newExhibition.StartDate" class="form-control museum-input" />
                            </div>
                            <div class="col-md-6">
                                <label class="museum-label">Дата окончания</label>
                                <InputDate @bind-Value="newExhibition.EndDate" class="form-control museum-input" />
                            </div>
                        </div>

                        <h6 class="museum-section-title">Локация музея</h6>
                        <div class="row g-3 mb-4">
                            <div class="col-md-12">
                                <label class="museum-label">Музей</label>
                                <InputText @bind-Value="newExhibition.MuseumName" class="form-control museum-input" required />
                            </div>
                            <div class="col-md-4">
                                <label class="museum-label">Город</label>
                                <InputText @bind-Value="newExhibition.City" class="form-control museum-input" required />
                            </div>
                            <div class="col-md-6">
                                <label class="museum-label">Улица</label>
                                <InputText @bind-Value="newExhibition.Street" class="form-control museum-input" required />
                            </div>
                            <div class="col-md-2">
                                <label class="museum-label">Дом</label>
                                <InputText @bind-Value="newExhibition.House" class="form-control museum-input" required />
                            </div>
                        </div>

                        <div class="d-flex justify-content-between align-items-center mb-3 pt-2 border-top">
                            <h6 class="museum-section-title border-0 m-0">Категории билетов</h6>
                            <button type="button" class="btn btn-sm btn-dark rounded-pill px-3 fw-bold" style="font-size: 0.7rem;" @onclick="AddTicket">
                                + ДОБАВИТЬ ТИП
                            </button>
                        </div>

                        @foreach (var ticketItem in newExhibition.Tickets)
                        {
                            <div class="row g-2 mb-2 p-2 rounded-3 mx-0 ticket-row align-items-center">
                                <div class="col-md-5">
                                    <InputText @bind-Value="ticketItem.Type" class="form-control form-control-sm input-clean fw-bold" placeholder="Тип билета" required />
                                </div>
                                <div class="col-md-3">
                                    <div class="input-group input-group-sm">
                                        <span class="input-group-text bg-transparent border-0 text-muted small">кол:</span>
                                        <InputNumber @bind-Value="ticketItem.Quantity" class="form-control input-clean" />
                                    </div>
                                </div>
                                <div class="col-md-3">
                                    <div class="input-group input-group-sm">
                                        <span class="input-group-text bg-transparent border-0 text-muted small">₽:</span>
                                        <InputNumber @bind-Value="ticketItem.Price" class="form-control input-clean fw-bold" />
                                    </div>
                                </div>
                                <div class="col-md-1 text-end">
                                    <button type="button" class="btn btn-link text-dark opacity-50 p-0" @onclick="() => newExhibition.Tickets.Remove(ticketItem)">
                                        <i class="bi bi-trash3"></i>
                                    </button>
                                </div>
                            </div>
                        }
                    </div>
                    <div class="modal-footer-custom">
                        <button type="button" class="btn btn-outline-dark btn-pill px-4 me-2" @onclick="CloseModal">ОТМЕНА</button>
                        <button type="submit" class="btn btn-dark btn-pill px-5 py-2 shadow-sm">ОПУБЛИКОВАТЬ ВЫСТАВКУ</button>
                    </div>
                </EditForm>
            </div>
        </div>
    </div>
}