@page "/exhibitions/{id:int}"
@inject HttpClient Https
@using Museum.Application.DTOs

@code {
    [Parameter]
    public int id { get; set; }

    private ExhibitionDetailsDTO? details;

    protected override async Task OnInitializedAsync()
    {
        details = await Https.GetFromJsonAsync<ExhibitionDetailsDTO>($"api/Exhibitions/{id}");
    }
}

<div class="container py-4">
    @if (details == null)
    {
        <div class="text-center py-5"><div class="spinner-border"></div></div>
    }
    else
    {
        <div class="row g-4">
            <div class="col-12 col-md-6">
                <img src="@(string.IsNullOrEmpty(details.Photo) ? "https://placehold.co/800x500" : details.Photo)" class="img-fluid rounded" />
                <h2 class="mt-3">@details.Name</h2>
                <p class="text-muted">@details.MuseumName — @details.MuseumComplex</p>
                <p><strong>Адрес:</strong> @details.Address</p>
                <p><strong>Период:</strong> @details.StartDate.ToString("dd.MM.yyyy") — @details.EndDate.ToString("dd.MM.yyyy") (@details.DurationDays дн.)</p>
                <p><strong>Статус:</strong> @details.StatusMessage</p>
            </div>
            <div class="col-12 col-md-6">
                <div class="card p-3 mb-3">
                    <h5>Билеты</h5>
                    @if (details.Tickets.Any())
                    {
                        <ul class="list-group list-group-flush">
                            @foreach (var t in details.Tickets)
                            {
                                <li class="list-group-item d-flex justify-content-between align-items-center">
                                    <div>
                                        <div class="fw-bold">@t.Type</div>
                                        <div class="text-muted">Количество: @t.Quantity</div>
                                    </div>
                                    <div class="fw-bold">@t.Price.ToString("N0") ₽</div>
                                </li>
                            }
                        </ul>
                    }
                    else
                    {
                        <div class="text-muted">Билеты не доступны</div>
                    }
                </div>

                <div class="card p-3">
                    <h5>График работы</h5>
                    @if (details.Schedule.Any())
                    {
                        <ul class="list-unstyled mb-0">
                            @foreach (var s in details.Schedule)
                            {
                                <li>@s.WeekDay: @s.Open.ToString() - @s.Close.ToString()</li>
                            }
                        </ul>
                    }
                </div>
            </div>
        </div>
    }
</div>
