@rendermode InteractiveServer
@page "/exhibitions"
@page "/"
@inject HttpClient Https
@using Museum.Application.DTOs
@using Microsoft.AspNetCore.WebUtilities



<div class="container py-4">
    <h1 class="display-6 fw-bold mb-5 mt-4 border-start border-dark border-4 ps-3">Экспозиции</h1>

    <div class="row">
        <div class="col-12 col-lg-3">
            <div class="filter-panel filter-vertical shadow-sm mb-4">
                <h6 class="mb-3">Фильтры</h6>
                <div class="mb-3">
                    <label class="filter-label">Название</label>
                    <input type="text" class="form-control-custom" @bind="filter.Name" @bind:event="oninput" placeholder="Поиск..." />
                </div>
                <div class="mb-3">
                    <label class="filter-label">Музей</label>
                    <input type="text" class="form-control-custom" @bind="filter.MuseumName" @bind:event="oninput" placeholder="Название музея" />
                </div>
                <div class="mb-3">
                    <label class="filter-label">Цена (от - до)</label>
                    <div class="d-flex gap-2">
                        <input type="number" class="form-control-custom" @bind="filter.MinPrice" placeholder="Мин" />
                        <input type="number" class="form-control-custom" @bind="filter.MaxPrice" placeholder="Макс" />
                    </div>
                </div>
                <div class="mb-3">
                    <label class="filter-label">Дата начала</label>
                    <input type="date" class="form-control-custom" @bind="filter.StartDate" />
                </div>
                <div class="mb-3">
                    <label class="filter-label">Дата окончания</label>
                    <input type="date" class="form-control-custom" @bind="filter.EndDate" />
                </div>
                <div class="d-grid">
                    <button type="button" class="btn btn-dark mb-2" @onclick="LoadExhibitions">Найти</button>
                    <button type="button" class="btn btn-outline-secondary" @onclick="ResetFilters">Сбросить</button>
                </div>
            </div>
        </div>

        <div class="col-12 col-lg-9">
            <div class="page-banner mb-4">
                <div class="banner-content">
                    <h3 class="mb-1">Текущие экспозиции</h3>
                    <p class="mb-0 text-muted">Узнайте о лучших выставках и специальных предложениях</p>
                </div>
            </div>

            @if (exhibitions == null)
            {
                <div class="text-center py-5"><div class="spinner-border"></div></div>
            }
            else
            {
                <div class="row row-cols-1 row-cols-md-2 row-cols-lg-3 g-4">
                    @foreach (var e in exhibitions)
                    {
                        <div class="col">
                            <div class="exhibition-card">
                                <div class="position-relative">
                                    <img src="@(string.IsNullOrEmpty(e.Photo) ? "https://dummyimage.com/600x400/000/fff&text=%D1%84%D0%BE%D1%82%D0%BE+%D0%B2%D1%8B%D1%81%D1%82%D0%B0%D0%B2%D0%BA%D0%B8" : e.Photo)" class="exhibition-image" />
                                    <div class="price-badge">от @e.MinPrice.ToString("N0") ₽</div>
                                </div>
                                <div class="card-body">
                                    <h5 class="title">@e.Name</h5>
                                    <p class="museum text-muted"><i class="bi bi-bank me-2"></i>@e.MuseumName</p>
                                    <NavLink class="btn btn-dark w-100 mt-auto" href="@($"/exhibitions/{e.ExhibitionID}")">Подробнее</NavLink>
                                </div>
                            </div>
                        </div>
                    }
                </div>
            }
        </div>
    </div>
</div>