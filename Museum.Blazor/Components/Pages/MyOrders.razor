@page "/orders"
@using Museum.Domain.DTOs
@inject HttpClient Http
@inject IJSRuntime JS
@inject NavigationManager Navigation
@attribute [Microsoft.AspNetCore.Authorization.Authorize]

<div class="container py-5 orders-container">
    <div class="d-flex justify-content-between align-items-center mb-5">
        <h2 class="page-title">Мои заказы</h2>
    </div>

    @if (orders == null)
    {
        <div class="text-center py-5">
            <div class="spinner-border text-dark"></div>
            <p class="mt-3 museum-label">Сверка данных с архивом...</p>
        </div>
    }
    else if (!orders.Any())
    {
        <div class="card empty-orders-card rounded-4 text-center">
            <div class="display-1 text-light mb-4"><i class="bi bi-ticket-perforated"></i></div>
            <h4 class="fw-bold text-uppercase" style="letter-spacing: 2px;">Заказов не обнаружено</h4>
            <p class="text-muted mb-4">Ваши билеты появятся здесь после оформления заказа.</p>
            <div class="d-flex justify-content-center">
                <a href="/" class="btn btn-museum-pay px-5 py-3">К списку выставок</a>
            </div>
        </div>
    }
    else
    {
        <div class="row g-4">
            @foreach (var order in orders.OrderByDescending(o => o.CreatedAt))
            {
                <div class="col-12">
                    <div class="card order-card border-0 rounded-4 overflow-hidden">
                        <div class="card-header bg-white order-header">
                            <div class="d-flex justify-content-between align-items-center">
                                <div>
                                    <div class="d-flex align-items-center gap-3 mb-1">
                                        <h5 class="order-number mb-0 text-uppercase">Заказ #@order.OrderId</h5>
                                        <span class="museum-badge @(order.Status == "Оплачен" ? "status-paid" : "status-pending")">
                                            @order.Status
                                        </span>
                                    </div>
                                    <div class="museum-label" style="font-size: 0.6rem;">
                                        <i class="bi bi-calendar3 me-1"></i> Оформлен: @order.CreatedAt.ToString("dd.MM.yyyy HH:mm")
                                    </div>
                                </div>
                                <div class="text-end">
                                    <div class="order-total-price">
                                        @order.Tickets.Sum(t => t.Price * t.Quantity).ToString("N0") ₽
                                    </div>
                                    @if (order.Status == "В ожидании")
                                    {
                                        <button class="btn btn-museum-pay btn-sm mt-2" @onclick="() => PayPendingOrder(order)">
                                            Оплатить сейчас
                                        </button>
                                    }
                                </div>
                            </div>
                        </div>

                        <div class="card-body p-4">
                            <div class="order-items-box rounded-4">
                                <h6 class="item-label mb-3 text-uppercase">Состав заказа</h6>
                                @foreach (var ticket in order.Tickets)
                                {
                                    <div class="d-flex justify-content-between align-items-center mb-2">
                                        <div>
                                            <span class="fw-bold text-uppercase" style="font-size: 0.85rem;">@ticket.TicketType</span>
                                            <span class="text-muted ms-2 small">× @ticket.Quantity</span>
                                        </div>
                                        <span class="fw-bold">@((ticket.Price * ticket.Quantity).ToString("N0")) ₽</span>
                                    </div>
                                }
                            </div>
                        </div>

                        @if (order.Status == "Оплачен")
                        {
                            <div class="card-footer bg-white border-0 p-4 pt-0">
                                <button class="btn btn-museum-outline w-100 py-3 rounded-3" @onclick="() => DownloadTicket(order)">
                                    <i class="bi bi-download me-2"></i> Получить электронный билет
                                </button>
                            </div>
                        }
                    </div>
                </div>
            }
        </div>
    }
</div>