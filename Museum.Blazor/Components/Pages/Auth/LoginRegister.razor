@page "/login"
@rendermode InteractiveServer
@using Museum.Application.DTOs
@inject HttpClient Https
@inject NavigationManager Navigation

<div class="login-wrapper">
    <div class="card shadow p-4 login-card">
        <h3 class="text-center mb-3">Museum</h3>

        <div class="d-flex mb-3">
            <button type="button"
                    class="@LoginTabClass w-50"
                    @onclick="SetLoginTab">
                Вход
            </button>

            <button type="button"
                    class="@RegisterTabClass w-50"
                    @onclick="SetRegisterTab">
                Регистрация
            </button>
        </div>

        @if (!string.IsNullOrEmpty(message))
        {
            <div class="alert alert-info">@message</div>
        }

        @if (activeTab == "login")
        {
            <EditForm Model="loginModel" OnValidSubmit="SubmitLogin" FormName="loginForm">
                <DataAnnotationsValidator />

                <div class="mb-3">
                    <label>Email</label>
                    <InputText class="form-control" @bind-Value="loginModel.Email" />
                </div>

                <div class="mb-3">
                    <label>Пароль</label>
                    <InputText type="password" class="form-control" @bind-Value="loginModel.Password" />
                </div>

                <button type="submit" class="btn btn-primary w-100">
                    Войти
                </button>
            </EditForm>
        }
        else
        {
            <EditForm Model="regModel" OnValidSubmit="SubmitRegister" FormName="registerForm">
                <DataAnnotationsValidator />

                <div class="mb-2">
                    <label>Email</label>
                    <InputText class="form-control" @bind-Value="regModel.Email" />
                </div>

                <div class="mb-2">
                    <label>Пароль</label>
                    <InputText type="password" class="form-control" @bind-Value="regModel.Password" />
                </div>

                <div class="mb-2">
                    <label>Имя</label>
                    <InputText class="form-control" @bind-Value="regModel.FirstName" />
                </div>

                <div class="mb-2">
                    <label>Фамилия</label>
                    <InputText class="form-control" @bind-Value="regModel.LastName" />
                </div>

                <div class="mb-2">
                    <label>Отчество</label>
                    <InputText class="form-control" @bind-Value="regModel.MiddleName" />
                </div>

                <div class="mb-3">
                    <label>Телефон</label>
                    <InputText class="form-control" @bind-Value="regModel.Phone" />
                </div>

                <button type="submit" class="btn btn-success w-100">
                    Зарегистрироваться
                </button>
            </EditForm>
        }
    </div>
</div>


@code {
    private string activeTab = "login";
    private string message;

    private LoginRequest loginModel = new();
    private RegisterRequest regModel = new();

    private string LoginTabClass =>
        activeTab == "login" ? "btn btn-primary" : "btn btn-outline-primary";

    private string RegisterTabClass =>
        activeTab == "register" ? "btn btn-primary" : "btn btn-outline-primary";

    private void SetLoginTab()
    {
        activeTab = "login";
        message = null;
    }

    private void SetRegisterTab()
    {
        activeTab = "register";
        message = null;
    }

    private async Task SubmitLogin()
    {
        var resp = await Https.PostAsJsonAsync("api/Auth/login", loginModel);

        if (resp.IsSuccessStatusCode)
        {
            message = "Вход выполнен успешно!";
            await Task.Delay(1000);
            Navigation.NavigateTo("/");
        }
        else
        {
            var error = await resp.Content.ReadAsStringAsync();
            message = "Ошибка входа: " + error;
        }
    }

    private async Task SubmitRegister()
    {
        var resp = await Https.PostAsJsonAsync("api/Auth/register", regModel);

        if (resp.IsSuccessStatusCode)
        {
            message = "Регистрация успешна! Теперь войдите.";
            activeTab = "login";
        }
        else
        {
            var error = await resp.Content.ReadAsStringAsync();
            message = "Ошибка регистрации: " + error;
        }
    }
}