@page "/admin/system"
@using Museum.Application.DTOs
@using Microsoft.AspNetCore.Authorization
@using System.Net.Http.Headers
@using System.IdentityModel.Tokens.Jwt
@using Microsoft.AspNetCore.Components.Forms

@inject HttpClient Http
@inject IJSRuntime JS
@inject NavigationManager Nav

<div class="admin-container p-4">
    <div class="container-fluid">
        <div class="d-flex justify-content-between align-items-center mb-4 border-bottom pb-3 admin-header-row">
            <h2 class="fw-bold mb-0 admin-title">SYSTEM ADMINISTRATION</h2>
            <div class="d-flex align-items-center">
                <span class="badge bg-dark rounded-pill px-3 py-2 fw-bold badge-root">ROOT</span>
            </div>
        </div>

        <div class="row">
            <div class="col-md-3">
                <div class="list-group border-0 bg-transparent">
                    <button class="list-group-item list-group-item-action sidebar-btn @(activeTab == "users" ? "active" : "")"
                            @onclick='() => SetTab("users")'>
                        <i class="bi bi-people-fill me-2"></i> Персонал
                    </button>
                    <button class="list-group-item list-group-item-action sidebar-btn @(activeTab == "orders" ? "active" : "")"
                            @onclick='LoadOrders'>
                        <i class="bi bi-receipt-cutoff me-2"></i> Все заказы
                    </button>
                    <button class="list-group-item list-group-item-action sidebar-btn @(activeTab == "stats" ? "active" : "")"
                            @onclick='LoadSales'>
                        <i class="bi bi-graph-up-arrow me-2"></i> Статистика
                    </button>
                    <button class="list-group-item list-group-item-action sidebar-btn @(activeTab == "export" ? "active" : "")"
                            @onclick='() => SetTab("export")'>
                        <i class="bi bi-cloud-download me-2"></i> Экспорт
                    </button>
                </div>
            </div>

            <div class="col-md-9">
                <div class="content-card p-4 shadow-sm">
                    @if (activeTab == "users")
                    {
                        <h4 class="fw-bold mb-4">Добавление сотрудника</h4>
                        <EditForm Model="newUser" OnValidSubmit="CreateUser" class="row g-3 p-4 bg-light rounded-4 mb-4">
                            <div class="col-md-6">
                                <label class="small fw-bold">Email</label>
                                <input @bind="newUser.Email" class="form-control" placeholder="example@museum.ru" required />
                            </div>
                            <div class="col-md-6">
                                <label class="small fw-bold">Пароль</label>
                                <input @bind="newUser.Password" type="password" class="form-control" required />
                            </div>
                            <div class="col-md-4">
                                <input @bind="newUser.FirstName" class="form-control" placeholder="Имя" required />
                            </div>
                            <div class="col-md-4">
                                <input @bind="newUser.LastName" class="form-control" placeholder="Фамилия" required />
                            </div>
                            <div class="col-md-4">
                                <select @bind="selectedRole" class="form-select">
                                    <option value="Администратор музея">Администратор музея</option>
                                    <option value="Администратор системы">Администратор системы</option>
                                </select>
                            </div>
                            <div class="col-12 mt-4">
                                <button type="submit" class="btn btn-museum-dark w-100 py-2">СОЗДАТЬ УЧЕТНУЮ ЗАПИСЬ</button>
                            </div>
                        </EditForm>

                        <h5 class="fw-bold mt-5 mb-3 text-danger">Удаление доступа</h5>
                        <div class="input-group mb-3">
                            <input @bind="emailToDelete" class="form-control" placeholder="Email пользователя" />
                            <button class="btn btn-danger px-4" @onclick="DeleteUser">УДАЛИТЬ</button>
                        </div>
                    }
                    else if (activeTab == "orders")
                    {
                        <div class="mb-4">
                            <h4 class="fw-bold m-0">Реестр транзакций</h4>
                        </div>

                        @if (orders == null)
                        {
                            <div class="text-center py-5"><div class="spinner-border text-dark"></div></div>
                        }
                        else
                        {
                            <div class="table-responsive">
                                <table class="table align-middle">
                                    <thead class="table-dark">
                                        <tr>
                                            <th class="table-header-id">ID</th>
                                            <th>Дата</th>
                                            <th>Сумма</th>
                                            <th class="table-header-status">Статус</th>
                                        </tr>
                                    </thead>
                                    <tbody>
                                        @foreach (var order in orders.OrderByDescending(o => o.CreatedAt))
                                        {
                                            <tr class="table-row-bordered">
                                                <td class="fw-bold table-cell-id">#@order.OrderId</td>
                                                <td class="small text-muted">@order.CreatedAt.ToString("dd.MM.yyyy HH:mm")</td>
                                                <td class="fw-bold">@order.Tickets.Sum(t => t.Price * t.Quantity).ToString("N0") ₽</td>
                                                <td class="table-cell-status">
                                                    <span class="badge @(order.Status == "Оплачен" ? "badge-paid" : "badge-wait")">
                                                        @order.Status
                                                    </span>
                                                </td>
                                            </tr>
                                        }
                                    </tbody>
                                </table>
                            </div>
                        }
                    }
                    else if (activeTab == "stats")
                    {
                        <h4 class="fw-bold mb-4 admin-title">Статистика продаж</h4>
                        
                        <div class="p-5 rounded-4 shadow-lg position-relative overflow-hidden mb-3 stats-card-revenue">
                            <div class="stats-circle-decor"></div>
                            <div class="small text-uppercase opacity-50 fw-bold mb-3 stats-label">Выручка </div>
                            <div class="d-flex align-items-baseline">
                                <span class="display-1 fw-bolder stats-value">
                                    @(orders?.Where(o => o.Status == "Оплачен").Sum(o => o.Tickets.Sum(t => t.Price * t.Quantity)).ToString("N0") ?? "0")
                                </span>
                                <span class="display-5 ms-4 fw-light opacity-50">₽</span>
                            </div>
                            <div class="mt-4 small opacity-50 d-flex align-items-center">
                                <div class="stats-sync-indicator"></div>
                                <span>Данные синхронизированы в реальном времени</span>
                            </div>
                        </div>

                        <button class="btn btn-museum-dark w-100 py-3 rounded-pill fw-bold text-uppercase shadow-sm btn-excel-report"
                                @onclick="DownloadExcel">
                            <i class="bi bi-file-earmark-arrow-down me-2"></i> Сформировать и скачать отчет в Excel
                        </button>
                    }
                    else if (activeTab == "export")
                    {
                        <h4 class="fw-bold mb-4">Экспорт системы</h4>
                        <div class="row g-3">
                            <div class="col-md-6">
                                <div class="p-4 border rounded-4 text-center">
                                    <p class="text-muted">Список всех пользователей</p>
                                    <button class="btn btn-outline-dark w-100" @onclick='() => ExportFile("api/admin/export/users", "Users.xlsx")'>СКАЧАТЬ</button>
                                </div>
                            </div>
                            <div class="col-md-6">
                                <div class="p-4 border rounded-4 text-center">
                                    <p class="text-muted">Данные по выставкам</p>
                                    <button class="btn btn-outline-dark w-100" @onclick='() => ExportFile("api/admin/export/exhibitions", "Exhibitions.xlsx")'>СКАЧАТЬ</button>
                                </div>
                            </div>
                        </div>
                    }
                </div>
            </div>
        </div>
    </div>
</div>

@if (!string.IsNullOrEmpty(message))
{
    <div class="position-fixed bottom-0 end-0 m-4 toast-container-custom">
        <div class="alert alert-dark shadow-lg border-0 rounded-3">@message</div>
    </div>
}