@page "/admin/system"
@using Museum.Application.DTOs
@using Microsoft.AspNetCore.Authorization
@using System.Net.Http.Headers
@using System.IdentityModel.Tokens.Jwt

@inject HttpClient Http
@inject IJSRuntime JS
@inject NavigationManager Nav

<div class="container-fluid mt-4">
    <h2 class="mb-4">Панель системного администратора</h2>

    <div class="row">
        <div class="col-md-3">
            <div class="list-group shadow-sm">
                <button class="list-group-item list-group-item-action @(activeTab == "users" ? "active" : "")" @onclick='() => activeTab = "users"'>Пользователи</button>
                <button class="list-group-item list-group-item-action @(activeTab == "orders" ? "active" : "")" @onclick='LoadOrders'>Все заказы</button>
                <button class="list-group-item list-group-item-action @(activeTab == "stats" ? "active" : "")" @onclick='LoadSales'>Статистика</button>
                <button class="list-group-item list-group-item-action @(activeTab == "export" ? "active" : "")" @onclick='() => activeTab = "export"'>Экспорт данных</button>
            </div>
        </div>

        <div class="col-md-9 border rounded p-4 bg-white shadow-sm">
            @if (activeTab == "users")
            {
                <h4>Управление персоналом</h4>
                <EditForm Model="newUser" OnValidSubmit="CreateUser" class="row g-3 mt-2">
                    <div class="col-md-6"><input @bind="newUser.Email" class="form-control" placeholder="Email" required /></div>
                    <div class="col-md-6"><input @bind="newUser.Password" type="password" class="form-control" placeholder="Пароль" required /></div>
                    <div class="col-md-4"><input @bind="newUser.FirstName" class="form-control" placeholder="Имя" required /></div>
                    <div class="col-md-4"><input @bind="newUser.LastName" class="form-control" placeholder="Фамилия" required /></div>
                    <div class="col-md-4">
                        <select @bind="selectedRole" class="form-select">
                            <option value="Администратор музея">Администратор музея</option>
                            <option value="Администратор системы">Администратор системы</option>
                        </select>
                    </div>
                    <div class="col-12"><button type="submit" class="btn btn-primary">Создать сотрудника</button></div>
                </EditForm>
                <hr class="my-4" />
                <div class="input-group w-75">
                    <input @bind="emailToDelete" class="form-control" placeholder="Email для удаления" />
                    <button class="btn btn-danger" @onclick="DeleteUser">Удалить пользователя</button>
                </div>
            }
            else if (activeTab == "orders")
            {
                <h4>Все заказы</h4>
                @if (orders == null)
                {
                    <div class="spinner-border text-primary"></div>
                }
                else
                {
                    <table class="table table-striped mt-3">
                        <thead>
                            <tr>
                                <th>№ Заказа</th>
                                <th>Дата</th>
                                <th>Сумма</th>
                                <th>Статус</th>
                                <th>Действие</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var order in orders)
                            {
                                <tr>
                                    <td>@order.OrderId</td>
                                    <td>@order.CreatedAt.ToShortDateString()</td>
                                    <td>@order.Tickets.Sum(t => t.Price * t.Quantity) ₽</td>
                                    <td><span class="badge @(order.Status == "Оплачен" ? "bg-success" : "bg-warning text-dark")">@order.Status</span></td>
                                    <td>
                                        @if (order.Status != "Оплачен")
                                        {
                                            <button class="btn btn-sm btn-outline-success" @onclick='() => UpdateStatus(order.OrderId, "Оплачен")'>Оплатить</button>
                                        }
                                    </td>
                                </tr>
                            }
                        </tbody>
                    </table>
                }
            }
            else if (activeTab == "stats")
            {
                <h4>Продажи выставок</h4>
                <button class="btn btn-success mb-3" @onclick="DownloadExcel">Скачать Excel отчет</button>
                @if (sales == null)
                {
                    <p>Загрузка...</p>
                }
                else
                {
                    <div class="list-group">
                        @foreach (var s in sales)
                        {
                            <div class="list-group-item d-flex justify-content-between align-items-center">
                                <strong>@s.ExhibitionName</strong>
                                <span class="badge bg-primary">Билетов: @s.TicketsSold</span>
                            </div>
                        }
                    </div>
                }
            }
            else if (activeTab == "export")
            {
                <h4>Выгрузка данных в Excel</h4>
                <div class="row mt-4">
                    <div class="col-md-6 border-end text-center">
                        <p>Список всех сотрудников и посетителей</p>
                        <button class="btn btn-outline-primary" @onclick='() => ExportFile("api/admin/export/users", "Users_List.xlsx")'>Скачать пользователей</button>
                    </div>
                    <div class="col-md-6 text-center">
                        <p>Список всех выставок и музеев</p>
                        <button class="btn btn-outline-success" @onclick='() => ExportFile("api/admin/export/exhibitions", "Exhibitions_List.xlsx")'>Скачать выставки</button>
                    </div>
                </div>
            }
        </div>
    </div>
</div>

@if (!string.IsNullOrEmpty(message))
{
    <div class="alert alert-info mt-3 mx-4">@message</div>
}

@code {
    private string activeTab = "users";
    private string message = "";
    private string selectedRole = "Администратор музея";
    private string emailToDelete = "";
    private bool isSystemAdmin = false;

    private RegisterRequest newUser = new();
    private List<OrderDto> orders;
    private IEnumerable<ExhibitionSalesDto> sales;

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender)
        {
            var token = await JS.InvokeAsync<string>("auth.getToken");
            if (string.IsNullOrEmpty(token))
            {
                Nav.NavigateTo("/login");
                return;
            }

            var handler = new JwtSecurityTokenHandler();
            var jwt = handler.ReadJwtToken(token.Trim('"'));
            var roles = jwt.Claims
                .Where(c => c.Type == "role" || c.Type.Contains("role"))
                .Select(c => c.Value).ToList();

            if (!roles.Contains("Администратор системы"))
            {
                Nav.NavigateTo("/");
            }
            else
            {
                isSystemAdmin = true;
                StateHasChanged();
            }
        }
    }

    private async Task SetAuthHeader()
    {
        var token = await JS.InvokeAsync<string>("auth.getToken");
        if (!string.IsNullOrEmpty(token))
            Http.DefaultRequestHeaders.Authorization = new AuthenticationHeaderValue("Bearer", token.Trim('"'));
    }

    private async Task ExportFile(string url, string fileName)
    {
        message = "Формирование файла...";
        await SetAuthHeader();
        var resp = await Http.GetAsync(url);
        if (resp.IsSuccessStatusCode)
        {
            var content = await resp.Content.ReadAsByteArrayAsync();
            await JS.InvokeVoidAsync("saveAsFile", fileName, Convert.ToBase64String(content));
            message = "Файл успешно скачан!";
        }
        else { message = "Ошибка при выгрузке данных."; }
    }

    private async Task CreateUser()
    {
        await SetAuthHeader();
        var resp = await Http.PostAsJsonAsync($"api/admin/users?role={selectedRole}", newUser);
        message = resp.IsSuccessStatusCode ? "Сотрудник создан!" : "Ошибка при создании";
    }

    private async Task DeleteUser()
    {
        if (string.IsNullOrEmpty(emailToDelete)) return;
        await SetAuthHeader();
        var resp = await Http.DeleteAsync($"api/admin/users/{emailToDelete}");
        message = resp.IsSuccessStatusCode ? "Пользователь удален" : "Ошибка удаления";
    }

    private async Task LoadOrders()
    {
        activeTab = "orders";
        await SetAuthHeader();
        orders = await Http.GetFromJsonAsync<List<OrderDto>>("api/admin/orders");
    }

    private async Task UpdateStatus(int id, string status)
    {
        await SetAuthHeader();
        var resp = await Http.PatchAsync($"api/admin/orders/{id}/status?status={status}", null);
        if (resp.IsSuccessStatusCode) await LoadOrders();
    }

    private async Task LoadSales()
    {
        activeTab = "stats";
        await SetAuthHeader();
        sales = await Http.GetFromJsonAsync<IEnumerable<ExhibitionSalesDto>>("api/admin/reports/sales");
    }

    private async Task DownloadExcel()
    {
        await ExportFile("api/admin/statistics", "Museum_Statistics.xlsx");
    }
}
