@using System.Security.Claims
@using System.IdentityModel.Tokens.Jwt
@inject IJSRuntime JS
@inject NavigationManager Nav

<nav class="custom-navbar">
    <div class="container nav-wrapper">
        <a class="navbar-brand-custom" href="/">MUSEUM</a>

        <div class="nav-right-group">
            <div class="nav-links">
                <NavLink class="nav-link-custom" href="/exhibitions">ВЫСТАВКИ</NavLink>
    
                @if (isLoggedIn)
                {
                    <NavLink class="nav-link-custom" href="/orders">МОИ ЗАКАЗЫ</NavLink>

                    @if (isSystemAdmin)
                    {
                        <NavLink class="nav-link-custom" href="/admin/system">СИСТЕМА</NavLink>
                    }
        
                    @if (isMuseumAdmin)
                    {
                        <NavLink class="nav-link-custom" href="/admin/museum">АДМИНКА МУЗЕЯ</NavLink>
                    }

                    <span class="user-email-nav" style="color: white; margin: 0 15px;">@userEmail</span>
                    <a class="btn-login-custom" style="cursor:pointer" @onclick="Logout">ВЫЙТИ</a>
                }
                else
                {
                    <NavLink class="btn-login-custom" href="/login">ВОЙТИ</NavLink>
                }
            </div>
        </div>
    </div>
</nav>

@code {
    private bool isLoggedIn = false;
    private bool isSystemAdmin = false;
    private bool isMuseumAdmin = false;
    private string userEmail = "";

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender)
        {
            await LoadUserStatus();
        }
    }

    private async Task LoadUserStatus()
    {
        try
        {
            var token = await JS.InvokeAsync<string>("auth.getToken");
            if (!string.IsNullOrEmpty(token) && token.Contains("."))
            {
                token = token.Trim('"');
                var handler = new JwtSecurityTokenHandler();
                if (handler.CanReadToken(token))
                {
                    var jwt = handler.ReadJwtToken(token);
                    var claims = jwt.Claims.ToList();

                    userEmail = claims.FirstOrDefault(c => c.Type == "email" || c.Type == ClaimTypes.Email || c.Type == "sub")?.Value ?? "";
                    
                    var roles = claims
                        .Where(c => c.Type == "role" || c.Type == ClaimTypes.Role || c.Type.Contains("role"))
                        .Select(c => c.Value).ToList();

                    isLoggedIn = true;
                    isSystemAdmin = roles.Contains("Администратор системы");
                    isMuseumAdmin = roles.Contains("Администратор музея");
                    
                    StateHasChanged();
                }
            }
        }
        catch { isLoggedIn = false; }
    }

    private async Task Logout()
    {
        await JS.InvokeVoidAsync("auth.removeToken");
        isLoggedIn = false;
        Nav.NavigateTo("/login", forceLoad: true);
    }
}
